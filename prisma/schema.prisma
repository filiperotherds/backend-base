generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(uuid())
  name                String?
  email               String    @unique
  password            String
  cpf                 String?   @unique
  avatarUrl           String?   @map("avatar_url")
  birthDate           DateTime? @map("birth_date")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  organization Organization?
  tokens       Token[]
  userProfile  UserProfile?

  @@map("user")
}

model UserProfile {
  id        String    @id @default(uuid())
  userId    String    @unique @map("user_id")
  addresses Address[]
  projects  Project[]
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profile")
}

model Token {
  id        String    @id @default(uuid())
  type      TokenType
  createdAt DateTime  @default(now()) @map("created_at")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

model Organization {
  id        String   @id @default(uuid())
  name      String?
  cnpj      String?  @unique
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ownerId String @unique @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id])

  address   Address[]
  estimates Estimate[]

  @@index(id)
  @@map("organization")
}

model Address {
  id             String        @id @default(uuid())
  street         String
  city           String
  state          String
  zipCode        String        @map("zip_code")
  country        String
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  number         String
  userProfileId  String?       @map("user_profile_id")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userProfile    UserProfile?  @relation(fields: [userProfileId], references: [id])

  @@map("address")
}

model Service {
  id          String    @id @default(uuid())
  name        String
  description String?
  slug        String    @unique
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  project     Project[]

  @@map("service")
}

model Project {
  id            String       @id @default(uuid())
  description   String?
  photoUrls     String[]     @map("photo_urls")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  serviceId     String       @map("service_id")
  userProfileId String?      @map("user_profile_id")
  service       Service      @relation(fields: [serviceId], references: [id])
  userProfile   UserProfile? @relation(fields: [userProfileId], references: [id])

  @@map("project")
}

model Estimate {
  id               String         @id @default(uuid())
  estimateNo       Int            @map("estimate_no")
  description      String?
  status           EstimateStatus @default(PENDING)
  createdAt        DateTime       @default(now()) @map("created_at")
  deliveryDeadline DateTime?      @map("delivery_deadline")

  installments  Int           @default(1)
  downPayment   Decimal?      @map("down_payment") @db.Decimal(10, 2)

  validity      DateTime?
  warrantyTerms String?   @map("warranty_terms")

  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  @@unique([organizationId, estimateNo])
  @@map("estimate")
}

enum TokenType {
  PASSWORD_RECOVER
}

enum EstimateStatus {
  PENDING
  APPROVED
  REJECTED
}

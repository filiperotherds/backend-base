generator client {
  provider        = "prisma-client"
  output          = "../src/generated/client"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                  String    @id @default(uuid())
  name                String?
  email               String    @unique
  password            String
  cpf                 String?   @unique
  avatarUrl           String?   @map("avatar_url")
  birthDate           DateTime? @map("birth_date")
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  isVerified          Boolean   @default(false) @map("is_verified")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  tokens Token[]

  professionalProfile ProfessionalProfile?
  serviceRequests     ServiceRequest[]

  @@map("user")
}

model Token {
  id        String    @id @default(uuid())
  type      TokenType
  code      String?
  createdAt DateTime  @default(now()) @map("created_at")
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tokens")
}

enum TokenType {
  PASSWORD_RECOVER
  EMAIL_VERIFICATION
}

// ------------------------------------------
// PERFIS E USUÁRIOS
// ------------------------------------------

model ProfessionalProfile {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating       Float @default(5.0)
  totalReviews Int   @default(0) @map("total_reviews")

  baseLatitude  Float? @map("base_latitude")
  baseLongitude Float? @map("base_longitude")
  maxDistanceKm Float  @default(30.0) @map("max_distance_km") // Raio de atuação

  // Descrição do que o profissional faz
  bio String?

  // Vetor de dimensão 384 gerado localmente (@xenova/transformers)
  embedding Unsupported("vector(384)")?

  isActive Boolean        @default(true) @map("is_active")
  matches  ServiceMatch[]

  @@map("professional_profile")
}

// ------------------------------------------
// SOLICITAÇÃO (O MOTOR DO SISTEMA)
// ------------------------------------------

model ServiceRequest {
  id String @id @default(uuid())

  clientId String @map("client_id")
  client   User   @relation(fields: [clientId], references: [id])

  description String

  // Vetor de dimensão 384
  embedding Unsupported("vector(384)")?

  isEmergency Boolean       @default(false) @map("is_emergency")
  scheduledAt DateTime?     @map("scheduled_at")
  status      ServiceStatus @default(SEARCHING)

  address             ServiceAddress?
  professionalMatches ServiceMatch[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_request")
}

enum ServiceStatus {
  SEARCHING
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

// ------------------------------------------
// ENDEREÇO DA SOLICITAÇÃO E GEOLOCALIZAÇÃO
// ------------------------------------------

model ServiceAddress {
  id      String @id @default(uuid())
  street  String
  number  String
  city    String
  state   String
  zipCode String @map("zip_code")

  latitude  Float
  longitude Float

  serviceRequestId String         @unique @map("service_request_id")
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@map("service_address")
}

// ------------------------------------------
// QUADRO DE AVISOS (DISPAROS / MATCHES)
// ------------------------------------------

model ServiceMatch {
  id String @id @default(uuid())

  serviceRequestId String         @map("service_request_id")
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  professionalProfileId String              @map("professional_profile_id")
  professional          ProfessionalProfile @relation(fields: [professionalProfileId], references: [id])

  similarityScore Float // Score semântico do vetor
  distanceKm      Float // Distância real calculada

  status MatchStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([serviceRequestId, professionalProfileId])
  @@map("service_match")
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  IGNORED
}
